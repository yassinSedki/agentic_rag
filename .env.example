# ── Application ──────────────────────────────────────────────────────
APP_ENV=dev
APP_HOST=0.0.0.0
APP_PORT=8000
LOG_LEVEL=INFO

# ── LLM (Ollama) ────────────────────────────────────────────────────
OLLAMA_BASE_URL=http://ollama:11434
OLLAMA_MODEL=llama3
OLLAMA_EMBED_MODEL=nomic-embed-text
OLLAMA_TIMEOUT_S=60

# ── Vector Database ──────────────────────────────────────────────────
VECTOR_DB=chroma
CHROMA_HOST=chroma
CHROMA_PORT=8001
CHROMA_COLLECTION=docs

# ── Retrieval ────────────────────────────────────────────────────────
TOP_K=4
MAX_CONTEXT_CHARS=12000
RETRIEVAL_TIMEOUT_S=10

# ── Chunking ─────────────────────────────────────────────────────────
CHUNK_SIZE=512
CHUNK_OVERLAP=64

# ── Security ─────────────────────────────────────────────────────────
API_KEY=changeme-to-a-secure-value
RATE_LIMIT=60/minute

# ── Observability ────────────────────────────────────────────────────
OTEL_EXPORTER_OTLP_ENDPOINT=http://otel:4317
ENABLE_PII_REDACTION=true

# ── Circuit Breaker ──────────────────────────────────────────────────
CIRCUIT_BREAKER_THRESHOLD=5
CIRCUIT_BREAKER_RESET_S=30

# ── Feature Flags ────────────────────────────────────────────────────
ENABLE_MEMORY=false
